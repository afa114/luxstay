<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> | LuxStay</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <style>
    .line-clamp-1{display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;}
    .line-clamp-2{display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
  </style>
</head>
<body class="bg-gray-50" x-data>

<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>

<div class="pt-16">
  <!-- Page header -->
  <div class="bg-gray-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold mb-2">Browse Hotels</h1>
      <p class="text-gray-400"><%= total %> properties found</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row gap-8">

      <!-- Filters Sidebar -->
      <aside class="lg:w-64 flex-shrink-0" x-data="{ open: false }">
        <button @click="open = !open" class="lg:hidden w-full flex items-center justify-between px-4 py-3 bg-white rounded-xl border border-gray-200 shadow-sm mb-4 font-medium text-gray-700">
          <span>Filters</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/></svg>
        </button>
        <div class="hidden lg:block space-y-4" :class="open ? '!block' : ''">
          <form action="/hotels" method="GET" class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 space-y-5">
            <!-- Search -->
            <div>
              <label class="text-sm font-semibold text-gray-700 block mb-2">Search</label>
              <input type="text" name="search" value="<%= query.search || '' %>" placeholder="Hotel or city..."
                class="w-full border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400"/>
            </div>
            <!-- Category -->
            <div>
              <label class="text-sm font-semibold text-gray-700 block mb-2">Category</label>
              <div class="space-y-1.5">
                <% ['luxury','resort','boutique','business','budget'].forEach(c => { %>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="category" value="<%= c %>" class="accent-amber-500" <%= query.category === c ? 'checked' : '' %>/>
                    <span class="text-sm text-gray-600 capitalize"><%= c %></span>
                  </label>
                <% }) %>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="category" value="" class="accent-amber-500" <%= !query.category ? 'checked' : '' %>/>
                  <span class="text-sm text-gray-600">All Categories</span>
                </label>
              </div>
            </div>
            <!-- Stars -->
            <div>
              <label class="text-sm font-semibold text-gray-700 block mb-2">Star Rating</label>
              <div class="space-y-1.5">
                <% [5,4,3].forEach(s => { %>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="stars" value="<%= s %>" class="accent-amber-500" <%= parseInt(query.stars) === s ? 'checked' : '' %>/>
                    <span class="text-amber-400 text-sm"><% for(let i=0;i<s;i++){%>★<%}%></span>
                  </label>
                <% }) %>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="stars" value="" class="accent-amber-500" <%= !query.stars ? 'checked' : '' %>/>
                  <span class="text-sm text-gray-600">Any Stars</span>
                </label>
              </div>
            </div>
            <!-- Price -->
            <div>
              <label class="text-sm font-semibold text-gray-700 block mb-2">Price / Night</label>
              <div class="grid grid-cols-2 gap-2">
                <input type="number" name="minPrice" value="<%= query.minPrice || '' %>" placeholder="Min $"
                  class="border border-gray-200 rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400"/>
                <input type="number" name="maxPrice" value="<%= query.maxPrice || '' %>" placeholder="Max $"
                  class="border border-gray-200 rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400"/>
              </div>
            </div>
            <button type="submit" class="w-full py-2.5 bg-amber-500 hover:bg-amber-600 text-white font-semibold rounded-xl transition-all">Apply Filters</button>
            <a href="/hotels" class="block text-center text-sm text-gray-400 hover:text-gray-600 transition-colors">Clear all</a>
          </form>
        </div>
      </aside>

      <!-- Hotel Grid -->
      <div class="flex-1">
        <% if (hotels.length === 0) { %>
          <div class="text-center py-20 bg-white rounded-2xl border border-gray-100">
            <p class="text-5xl mb-4">🏨</p>
            <h3 class="text-xl font-bold text-gray-700 mb-2">No hotels found</h3>
            <p class="text-gray-400 mb-6">Try adjusting your filters</p>
            <a href="/hotels" class="px-6 py-2.5 bg-amber-500 text-white rounded-full font-semibold hover:bg-amber-600">View all hotels</a>
          </div>
        <% } else { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
            <% hotels.forEach(hotel => { %>
              <%- include('../partials/hotel-card', { hotel }) %>
            <% }) %>
          </div>

          <!-- Pagination -->
          <% if (pages > 1) { %>
            <div class="flex justify-center mt-10 gap-2">
              <% for(let i = 1; i <= pages; i++) { %>
                <a href="/hotels?<%= new URLSearchParams({...query, page: i}).toString() %>"
                  class="w-10 h-10 flex items-center justify-center rounded-full text-sm font-medium transition-all
                  <%= i === currentPage ? 'bg-amber-500 text-white shadow-md' : 'bg-white text-gray-600 border border-gray-200 hover:border-amber-400' %>">
                  <%= i %>
                </a>
              <% } %>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
