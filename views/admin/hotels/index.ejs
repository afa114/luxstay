<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Manage Hotels | Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-gray-100" x-data>
<%- include('../../partials/navbar') %>
<%- include('../../partials/flash') %>
<div class="pt-16 min-h-screen">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/admin" class="text-sm text-gray-400 hover:text-gray-600">← Dashboard</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-1">Hotels (<%= hotels.length %>)</h1>
      </div>
      <a href="/admin/hotels/new" class="px-4 py-2.5 bg-amber-500 hover:bg-amber-600 text-white text-sm font-semibold rounded-xl transition-all shadow-sm">+ New Hotel</a>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 text-gray-500 text-xs uppercase text-left">
            <th class="px-5 py-3 font-medium">Hotel</th>
            <th class="px-5 py-3 font-medium">Location</th>
            <th class="px-5 py-3 font-medium">Category</th>
            <th class="px-5 py-3 font-medium">Stars</th>
            <th class="px-5 py-3 font-medium">Rooms</th>
            <th class="px-5 py-3 font-medium">Rating</th>
            <th class="px-5 py-3 font-medium">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% hotels.forEach(h => { %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-4">
                <div class="flex items-center gap-3">
                  <% if (h.mainImage) { %>
                    <img src="<%= h.mainImage %>" class="w-12 h-10 object-cover rounded-lg" onerror="this.style.display='none'"/>
                  <% } %>
                  <div>
                    <p class="font-semibold text-gray-800"><%= h.name %></p>
                    <p class="text-xs text-gray-400"><%= h.slug %></p>
                  </div>
                </div>
              </td>
              <td class="px-5 py-4 text-gray-600"><%= h.city %>, <%= h.country %></td>
              <td class="px-5 py-4"><span class="px-2 py-0.5 bg-amber-100 text-amber-700 text-xs rounded-full capitalize"><%= h.category %></span></td>
              <td class="px-5 py-4 text-amber-400"><% for(let i=0;i<h.stars;i++){%>★<%}%></td>
              <td class="px-5 py-4">
                <a href="/admin/hotels/<%= h.id %>/rooms" class="text-blue-600 hover:text-blue-700 font-medium"><%= h.rooms ? h.rooms.length : 0 %> rooms</a>
              </td>
              <td class="px-5 py-4 text-gray-700"><%= h.rating %> (<%= h.reviewCount %>)</td>
              <td class="px-5 py-4">
                <div class="flex items-center gap-2">
                  <a href="/hotels/<%= h.slug %>" class="px-2.5 py-1 text-xs bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200">View</a>
                  <a href="/admin/hotels/<%= h.id %>/edit" class="px-2.5 py-1 text-xs bg-blue-100 text-blue-600 rounded-lg hover:bg-blue-200">Edit</a>
                  <form action="/admin/hotels/<%= h.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this hotel?')">
                    <button type="submit" class="px-2.5 py-1 text-xs bg-red-100 text-red-600 rounded-lg hover:bg-red-200">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
</body>
</html>
