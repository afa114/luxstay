<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>All Bookings | Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-gray-100" x-data>
<%- include('../partials/navbar') %>
<%- include('../partials/flash') %>
<div class="pt-16 min-h-screen">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-6">
      <a href="/admin" class="text-sm text-gray-400 hover:text-gray-600">← Dashboard</a>
      <h1 class="text-2xl font-bold text-gray-900 mt-1">All Bookings (<%= bookings.length %>)</h1>
    </div>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 text-gray-500 text-xs uppercase text-left">
              <th class="px-4 py-3 font-medium">Ref</th>
              <th class="px-4 py-3 font-medium">Guest</th>
              <th class="px-4 py-3 font-medium">Hotel / Room</th>
              <th class="px-4 py-3 font-medium">Check-in</th>
              <th class="px-4 py-3 font-medium">Check-out</th>
              <th class="px-4 py-3 font-medium">Total</th>
              <th class="px-4 py-3 font-medium">Status</th>
              <th class="px-4 py-3 font-medium">Update</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% bookings.forEach(b => { %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 font-mono text-xs text-gray-500"><%= b.bookingRef %></td>
                <td class="px-4 py-3">
                  <p class="font-semibold text-gray-800"><%= b.user ? b.user.name : b.guestName %></p>
                  <p class="text-xs text-gray-400"><%= b.guestEmail %></p>
                </td>
                <td class="px-4 py-3">
                  <p class="font-medium text-gray-700"><%= b.hotel ? b.hotel.name : '—' %></p>
                  <p class="text-xs text-gray-400"><%= b.room ? b.room.name : '—' %></p>
                </td>
                <td class="px-4 py-3 text-gray-600"><%= formatDate(b.checkIn) %></td>
                <td class="px-4 py-3 text-gray-600"><%= formatDate(b.checkOut) %></td>
                <td class="px-4 py-3 font-bold text-amber-600"><%= formatCurrency(b.totalPrice) %></td>
                <td class="px-4 py-3">
                  <span class="px-2 py-0.5 text-xs font-bold rounded-full
                    <%= b.status==='confirmed'?'bg-green-100 text-green-700':
                        b.status==='cancelled'?'bg-red-100 text-red-700':
                        b.status==='completed'?'bg-blue-100 text-blue-700':
                        'bg-yellow-100 text-yellow-700' %> capitalize">
                    <%= b.status %>
                  </span>
                </td>
                <td class="px-4 py-3">
                  <form action="/admin/bookings/<%= b.id %>/status" method="POST" class="flex gap-1">
                    <select name="status" class="border border-gray-200 rounded-lg px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-amber-400">
                      <% ['pending','confirmed','completed','cancelled'].forEach(s => { %>
                        <option value="<%= s %>" <%= b.status===s?'selected':'' %>><%= s %></option>
                      <% }) %>
                    </select>
                    <button type="submit" class="px-2 py-1 bg-amber-500 text-white text-xs rounded-lg hover:bg-amber-600">Save</button>
                  </form>
                </td>
              </tr>
            <% }) %>
            <% if (bookings.length === 0) { %>
              <tr><td colspan="8" class="px-5 py-10 text-center text-gray-400">No bookings found</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
</body>
</html>
