<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>404 Not Found | LuxStay</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center px-4">
  <div class="text-center">
    <p class="text-8xl font-black text-amber-400 mb-4">404</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Page Not Found</h1>
    <p class="text-gray-500 mb-8">The page you're looking for doesn't exist.</p>
