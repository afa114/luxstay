<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Server Error | LuxStay</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center px-4">
  <div class="text-center">
    <p class="text-8xl font-black text-red-400 mb-4">500</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Server Error</h1>
    <p class="text-gray-500 mb-2">Something went wrong on our end.</p>
    <% if (typeof error !== 'undefined' && process && process.env && process.env.NODE_ENV === 'development') { %>
      <p class="text-sm text-red-500 mb-6 font-mono bg-red-50 px-4 py-2 rounded-lg"><%= error %></p>
    <% } %>
    <a href="/" class="px-6 py-3 bg-amber-500 hover:bg-amber-600 text-white font-semibold rounded-full transition-all">Go Home</a>
  </div>
</body>
</html>
