<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Booking Confirmed | LuxStay</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-gray-50" x-data>

<%- include('../partials/navbar') %>

<div class="pt-16 min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-lg">
    <!-- Success animation -->
    <div class="text-center mb-8">
      <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4 animate-bounce">
        <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Booking Confirmed!</h1>
      <p class="text-gray-500">Your reservation has been successfully made.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
      <!-- Hotel image -->
      <% if (booking.hotel && booking.hotel.mainImage) { %>
        <img src="<%= booking.hotel.mainImage %>" alt="<%= booking.hotel.name %>" class="w-full h-40 object-cover"/>
      <% } %>

      <div class="p-6">
        <!-- Booking ref -->
        <div class="flex items-center justify-between mb-5 p-4 bg-amber-50 rounded-xl border border-amber-200">
          <div>
            <p class="text-xs text-amber-600 font-medium uppercase tracking-wider">Booking Reference</p>
            <p class="text-2xl font-bold text-amber-700 font-mono"><%= booking.bookingRef %></p>
          </div>
          <span class="px-3 py-1.5 bg-green-100 text-green-700 text-sm font-bold rounded-full capitalize"><%= booking.status %></span>
        </div>

        <!-- Details -->
        <div class="space-y-3 text-sm">
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-500">Hotel</span>
            <span class="font-semibold text-gray-800"><%= booking.hotel ? booking.hotel.name : 'N/A' %></span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-500">Room</span>
            <span class="font-semibold text-gray-800"><%= booking.room ? booking.room.name : 'N/A' %></span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-500">Guest</span>
            <span class="font-semibold text-gray-800"><%= booking.guestName %></span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-500">Check-in</span>
            <span class="font-semibold text-gray-800"><%= formatDate(booking.checkIn) %></span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-500">Check-out</span>
            <span class="font-semibold text-gray-800"><%= formatDate(booking.checkOut) %></span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-500">Duration</span>
            <span class="font-semibold text-gray-800"><%= booking.nights %> night<%= booking.nights > 1 ? 's' : '' %></span>
          </div>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="text-gray-500">Guests</span>
            <span class="font-semibold text-gray-800"><%= booking.guests %></span>
          </div>
          <div class="flex justify-between py-2 text-base font-bold">
            <span class="text-gray-800">Total Paid</span>
            <span class="text-green-600"><%= formatCurrency(booking.totalPrice) %></span>
          </div>
        </div>

        <div class="mt-6 p-4 bg-blue-50 rounded-xl border border-blue-100 text-sm text-blue-700">
          <p>📧 A confirmation email has been sent to <strong><%= booking.guestEmail %></strong></p>
        </div>

        <div class="mt-6 grid grid-cols-2 gap-3">
          <a href="/bookings" class="py-3 border border-gray-200 text-gray-700 font-semibold text-center rounded-xl hover:bg-gray-50 transition-all">
            My Bookings
          </a>
          <a href="/hotels" class="py-3 bg-amber-500 hover:bg-amber-600 text-white font-semibold text-center rounded-xl transition-all shadow-md">
            Browse More Hotels
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
