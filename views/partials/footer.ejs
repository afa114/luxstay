<footer class="bg-gray-900 text-gray-400 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 bg-gradient-to-br from-amber-500 to-orange-600 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
          </div>
          <span class="text-xl font-bold text-white">Lux<span class="text-amber-400">Stay</span></span>
        </div>
        <p class="text-sm leading-relaxed max-w-sm">Discover the world's finest hotels and resorts. From intimate boutique properties to grand luxury palaces, we curate the very best in hospitality.</p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-3">Explore</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/hotels" class="hover:text-amber-400 transition-colors">All Hotels</a></li>
          <li><a href="/hotels?category=luxury" class="hover:text-amber-400 transition-colors">Luxury Hotels</a></li>
          <li><a href="/hotels?category=resort" class="hover:text-amber-400 transition-colors">Resorts</a></li>
          <li><a href="/hotels?category=boutique" class="hover:text-amber-400 transition-colors">Boutique</a></li>
          <li><a href="/hotels?category=business" class="hover:text-amber-400 transition-colors">Business</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-3">Account</h4>
        <ul class="space-y-2 text-sm">
          <% if (currentUser) { %>
            <li><a href="/bookings" class="hover:text-amber-400 transition-colors">My Bookings</a></li>
            <li><a href="/auth/logout" class="hover:text-amber-400 transition-colors">Sign Out</a></li>
          <% } else { %>
            <li><a href="/auth/login" class="hover:text-amber-400 transition-colors">Sign In</a></li>
            <li><a href="/auth/register" class="hover:text-amber-400 transition-colors">Register</a></li>
          <% } %>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center text-xs">
      <p>© 2024 LuxStay. All rights reserved.</p>
      <p class="mt-2 sm:mt-0">Built with Node.js, Express & ❤️</p>
    </div>
  </div>
</footer>
